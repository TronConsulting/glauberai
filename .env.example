# ==========================================
# GLAUBER AI - ENVIRONMENT VARIABLES EXAMPLE
# ==========================================
# Rename this file to .env.local and fill in the API keys for the services you want to use.
# NOTE: Never commit your actual .env.local file to version control!

# ------------------------------------------
# TRULY FREE APIs (No Keys Required)
# ------------------------------------------
# - Pollinations AI: Completely free, no key needed.
# - Ollama Local: Completely free, runs locally, no key needed.

# ------------------------------------------
# APIs WITH GENEROUS FREE TIERS
# ------------------------------------------

# GROQ (Extremely fast open-source models like Llama 3)
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# TOGETHER AI (Variety of open-source models)
# Get a free key at: https://api.together.xyz/settings/api-keys
TOGETHER_GLAUBER_API=your_together_api_key_here

# GOOGLE GEMINI (Powerful multimodal models with a great free tier)
# Get a free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# HUGGING FACE (Inference endpoints for many open models)
# Get a free key at: https://huggingface.co/settings/tokens
HUG_GLAUBER_API=your_huggingface_api_key_here

# ------------------------------------------
# PAID APIs (Usage based pricing)
# ------------------------------------------

# OPENAI (GPT-4, DALL-E, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# ANTHROPIC (Claude 3)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DEEPSEEK (High performance reasoning and coding)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OPENROUTER (Unified API for many models)
OPENROUTER_GLAUBER_API=your_openrouter_api_key_here

# STABILITY AI (Image Generation)
STABILITY_API_KEY=your_stability_api_key_here

# ELEVENLABS (High quality Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
