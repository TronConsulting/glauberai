# ===== CORE APPLICATION =====
# Database
DATABASE_URL="your_database_url_here"

# JWT Secret (generate a secure random string)
JWT_SECRET="your_jwt_secret_here"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===== BILLING (Optional) =====
# Stripe (for billing - only needed if using paid plans)
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"

# ===== AI MODEL API KEYS =====
# The system automatically detects which API keys are available and 
# only loads models for providers with valid keys.

# 🆓 FREE MODELS (Recommended to start with)
# HuggingFace - Provides access to ALL open-source models
HUGGINGFACE_API_KEY="your_huggingface_token_here"

# 💰 PREMIUM MODELS (Add as needed)
# OpenAI - GPT-4o, GPT-4o-mini, GPT-3.5-turbo
OPENAI_API_KEY="your_openai_api_key_here"

# Anthropic - Claude 3.5 Sonnet, Claude 3 Haiku
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Google - Gemini 1.5 Pro, Gemini 1.5 Flash
GOOGLE_API_KEY="your_google_api_key_here"

# ⚡ FAST INFERENCE PROVIDERS
# Groq - Ultra-fast inference for Llama and Mixtral
GROQ_API_KEY="your_groq_api_key_here"

# Together AI - Fast inference for various models
TOGETHER_API_KEY="your_together_api_key_here"

# Perplexity - Fast models with web search
PERPLEXITY_API_KEY="your_perplexity_api_key_here"

# 🧪 ADDITIONAL PROVIDERS (Optional)
# Cohere - Command models
COHERE_API_KEY="your_cohere_api_key_here"

# Mistral AI - Official Mistral models
MISTRAL_API_KEY="your_mistral_api_key_here"

# Replicate - Various models including image generation
REPLICATE_API_KEY="your_replicate_api_key_here"

# ===== SPECIALIZED AI MODES (NEW) =====
# Image Generation
# Stability AI - Stable Diffusion XL (required for Stability image generation)
STABILITY_API_KEY="your_stability_api_key_here"

# Text-to-Speech (Premium)
# ElevenLabs - Ultra-realistic voice synthesis
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"

# Audio Transcription (Alternative to OpenAI Whisper)
# AssemblyAI - Speech recognition with speaker diarization
ASSEMBLYAI_API_KEY="your_assemblyai_api_key_here"
# Deepgram - Real-time speech recognition
DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# NOTE: OpenAI API key provides access to:
# - DALL-E 2/3 (image generation)
# - Whisper (speech-to-text)
# - TTS-1/TTS-1-HD (text-to-speech)
# - text-embedding-3-small/large (embeddings)

# ===== QUICK START GUIDE =====
# 
# 🚀 OPTION 1: Free Only (Recommended for testing)
# 1. Get HuggingFace API key: https://huggingface.co/settings/tokens
# 2. Set HUGGINGFACE_API_KEY above
# 3. Deploy - you'll have 12+ free models including:
#    - Llama 2 7B/13B Chat, Code Llama 7B/13B
#    - Mistral 7B, Mixtral 8x7B, StarCoder
#    - Flan-T5, Phi-2, GPT-2 (fallback)
#
# 🎯 OPTION 2: Mixed (Free + Premium)
# 1. Add HUGGINGFACE_API_KEY for free models
# 2. Add OPENAI_API_KEY or ANTHROPIC_API_KEY for premium quality
# 3. System automatically uses best model for each task
#
# ⚡ OPTION 3: Speed Focused
# 1. Add GROQ_API_KEY for ultra-fast inference
# 2. Add HUGGINGFACE_API_KEY for free fallbacks
# 3. Enjoy lightning-fast responses
#
# 💎 OPTION 4: Full Premium
# 1. Add OpenAI, Anthropic, Google API keys
# 2. Add HuggingFace for free fallbacks
# 3. Get best quality with intelligent routing

# ===== SYSTEM FEATURES =====
# 
# 🧠 INTELLIGENT ROUTING
# - Automatically selects best model for each query type
# - Code questions → Code Llama or GPT-4
# - Image analysis → GPT-4o or Claude 3.5 Sonnet
# - Fast queries → Groq models or Phi-2
# - Complex reasoning → Claude 3.5 Sonnet or GPT-4o
#
# 🔄 AUTOMATIC FALLBACKS
# - If primary model fails, tries alternatives
# - Always falls back to free models
# - Never leaves users without a response
#
# 💰 COST OPTIMIZATION
# - Prefers free models when quality is sufficient
# - Uses expensive models only when necessary
# - Tracks and displays costs per request
#
# 📊 REAL-TIME MONITORING
# - API endpoints: /api/admin/system
# - Health checks, model status, provider status
# - Performance metrics and recommendations

# ===== MODEL CATEGORIES =====
#
# 📝 CHAT: General conversation and Q&A
# - Free: Llama 2 7B/13B Chat, Mistral 7B, Phi-2
# - Premium: GPT-4o-mini, Claude 3 Haiku
#
# 💻 CODE: Programming and development
# - Free: Code Llama 7B/13B, StarCoder
# - Premium: GPT-4o, Claude 3.5 Sonnet
#
# 🧠 REASONING: Complex analysis and logic
# - Free: Llama 2 13B, Mixtral 8x7B
# - Premium: Claude 3.5 Sonnet, GPT-4o
#
# 🎨 CREATIVE: Content generation and writing
# - Free: Llama 2 models, Mistral models
# - Premium: GPT-4o, Claude 3.5 Sonnet
#
# ⚡ FAST: Quick responses and real-time
# - Free: Phi-2, GPT-2
# - Premium: Groq models, GPT-4o-mini
#
# 👁️ VISION: Image and visual analysis
# - Premium only: GPT-4o, Claude 3.5 Sonnet, Gemini 1.5 Pro
#
# 🎭 MULTIMODAL: Multiple content types
# - Premium only: GPT-4o, Gemini 1.5 Pro

# ===== MONITORING ENDPOINTS =====
# 
# 📊 System Status
# GET /api/admin/system?action=status
# 
# 🔧 List All Models  
# GET /api/admin/system?action=models
#
# 🏥 Health Check
# GET /api/admin/system?action=health
#
# 🧪 Test System
# GET /api/admin/system?action=test
#
# 🔄 Refresh Models
# POST /api/admin/system {"action": "refresh_models"}
#
# 🧹 Clear Cache
# POST /api/admin/system {"action": "clear_cache"}
#
# 🎯 Test Specific Model
# POST /api/admin/system {"action": "test_model", "data": {"modelId": "llama-2-7b-chat"}}

# ===== COST INFORMATION =====
#
# 💰 FREE MODELS (HuggingFace)
# - 30,000 characters/month free tier
# - Unlimited with HuggingFace Pro ($9/month)
# - All open-source models: $0/token
#
# 💎 PREMIUM MODEL COSTS (per 1K tokens)
# - GPT-4o: $5.00
# - Claude 3.5 Sonnet: $3.00  
# - GPT-4o-mini: $0.15
# - Claude 3 Haiku: $0.25
# - Gemini 1.5 Flash: $0.075
# - Groq Llama 3 70B: $0.59
#
# 🎯 COST OPTIMIZATION TIPS
# - Set preferFree=true in requests to use free models when possible
# - Use maxCost parameter to limit spending per request
# - Monitor usage in admin dashboard
# - Free models handle 80% of queries effectively

# ===== TROUBLESHOOTING =====
#
# ❌ "No AI models are currently available"
# → Add at least one API key (HuggingFace recommended)
# → Check API key format and validity
# → Verify network connectivity
#
# ❌ "Vision capabilities required but no vision models available"  
# → Add OpenAI, Anthropic, or Google API key
# → Vision requires premium models
#
# ❌ "Rate limit exceeded"
# → Wait and retry (automatic exponential backoff)
# → Upgrade to higher tier with provider
# → Use alternative providers
#
# ❌ "Model not responding"
# → System automatically tries fallback models
# → Check /api/admin/system?action=health
# → HuggingFace models may need 30s to "warm up"
#
# 🔧 Debug Commands
# curl localhost:3000/api/admin/system?action=health
# curl localhost:3000/api/admin/system?action=test
# curl localhost:3000/api/admin/system?action=models

# ===== DEPLOYMENT CHECKLIST =====
#
# ✅ Basic Setup (Free models only)
# 1. Set DATABASE_URL and JWT_SECRET
# 2. Set HUGGINGFACE_API_KEY
# 3. Deploy and test
#
# ✅ Production Setup (Recommended)
# 1. Add HUGGINGFACE_API_KEY (free fallbacks)
# 2. Add OPENAI_API_KEY or ANTHROPIC_API_KEY (quality)
# 3. Add GROQ_API_KEY (speed)
# 4. Configure monitoring alerts
# 5. Set up usage tracking
#
# ✅ Enterprise Setup (Full features)
# 1. All API keys for maximum flexibility
# 2. Configure rate limiting and quotas
# 3. Set up logging and analytics
# 4. Enable premium features
# 5. Configure backup providers

# ===== ENVIRONMENT VARIABLES REFERENCE =====
# 
# Required for basic functionality:
# - DATABASE_URL: PostgreSQL connection string
# - JWT_SECRET: Secret for JWT token signing
# - HUGGINGFACE_API_KEY: Free models access
#
# Optional for enhanced functionality:
# - OPENAI_API_KEY: GPT models
# - ANTHROPIC_API_KEY: Claude models  
# - GOOGLE_API_KEY: Gemini models
# - GROQ_API_KEY: Fast inference
# - All other AI provider keys: Extended model selection
#
# Optional for billing:
# - STRIPE_*: Payment processing
#
# The system gracefully handles missing API keys by:
# 1. Only loading models for available providers
# 2. Automatically routing to available alternatives
# 3. Always maintaining free model fallbacks
# 4. Providing clear error messages and recommendations