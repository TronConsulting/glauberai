generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  fullName         String?
  plan             UserPlan @default(STARTER)
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Security enhancements
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  backupCodes      String[]  @default([])
  trustedDevices   Json?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  // Relations
  requests            Request[]
  billing             Billing[]
  files               File[]
  subscriptions       Subscription[]
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]
  conversations       Conversation[]
  apiKeys             ApiKey[]
}

model File {
  id           String   @id @default(uuid())
  userId       String
  requestId    String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String // File path in storage
  url          String? // Public URL if applicable
  metadata     Json? // Additional file metadata
  createdAt    DateTime @default(now())

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)
}

model Request {
  id        String   @id @default(uuid())
  userId    String
  query     String
  model     String
  tokens    Int
  cost      Float    @default(0)
  status    String   @default("completed") // completed, failed, pending
  response  String? // Store the AI response
  fileCount Int      @default(0) // Number of files attached
  createdAt DateTime @default(now())

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  files File[]
}

model Billing {
  id        String   @id @default(uuid())
  userId    String
  plan      UserPlan
  amount    Float
  status    String   @default("pending") // pending, paid, failed, cancelled
  period    String // monthly, annual
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  stripeSubscriptionId String   @unique
  stripePriceId        String
  stripeCustomerId     String
  status               String // active, canceled, past_due, etc.
  plan                 UserPlan
  billingCycle         String // monthly, annual
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Conversation {
  id         String    @id @default(uuid())
  userId     String
  title      String?
  model      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, createdAt])
  @@index([userId, archivedAt])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String   @db.Text
  model          String?
  tokens         Int      @default(0)
  cost           Float    @default(0)
  attachments    Json?
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  ipAddress    String
  userAgent    String
  expiresAt    DateTime
  lastActivity DateTime @updatedAt
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  sessionId  String?
  action     String
  resource   String?
  resourceId String?
  ipAddress  String
  userAgent  String
  location   Json?
  metadata   Json?
  changes    Json?
  status     String
  severity   String
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, status, createdAt])
  @@index([severity, createdAt])
  @@index([ipAddress, createdAt])
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  name       String
  keyHash    String    @unique
  prefix     String
  scopes     String[]
  rateLimit  Int?
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}
enum Provider {
  OPENAI
  ANTHROPIC
  GOOGLE
  COHERE
  MISTRAL
  META
  HUGGINGFACE
  OLLAMA
  TOGETHER
  PERPLEXITY
  GROQ
  REPLICATE
  STABILITY
  MIDJOURNEY
  RUNPOD
  DEEPSEEK
  XAI
  FIREWORKS
  ANYSCALE
  NVIDIA
  QWEN
}

enum ProviderApiKeyStatus {
  ACTIVE
  BACKUP
  EXPIRED
  REVOKED
  COMPROMISED
  DISABLED
}

model ProviderApiKey {
  id               String               @id @default(uuid())
  provider         Provider
  name             String
  description      String?
  keyHash          String               @unique
  prefix           String
  status           ProviderApiKeyStatus @default(ACTIVE)
  expiresAt        DateTime?
  revokedAt        DateTime?
  failureCount     Int                  @default(0)
  consecutiveFailures Int               @default(0)
  lastFailureAt    DateTime?
  monthlyLimit     Float                @default(50)
  monthlyUsage     Float                @default(0)
  totalUsage       Float                @default(0)
  lastUsedAt       DateTime?
  priority         Int                  @default(0)
  isPrimary        Boolean              @default(false)
  isBackup         Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  usageRecords     ProviderApiKeyUsage[]
  rotations        ProviderApiKeyRotation[]
}

model ProviderApiKeyUsage {
  id               String         @id @default(uuid())
  providerApiKeyId String
  provider         Provider
  model            String
  tokens           Int            @default(0)
  cost             Float          @default(0)
  success          Boolean        @default(true)
  error            String?
  requestId        String?
  userId           String?
  createdAt        DateTime       @default(now())

  providerApiKey ProviderApiKey @relation(fields: [providerApiKeyId], references: [id], onDelete: Cascade)
}

model ProviderApiKeyRotation {
  id                  String         @id @default(uuid())
  providerApiKeyId    String
  rotatedToKeyId      String?
  event               String
  reason              String?
  createdAt           DateTime       @default(now())

  providerApiKey ProviderApiKey @relation(fields: [providerApiKeyId], references: [id], onDelete: Cascade)
}

// User Model Preferences - Track which models users prefer for different query types
model UserModelPreference {
  id                String   @id @default(uuid())
  userId            String
  modelId           String
  queryType         String   // CHAT, CODE, VISION, REASONING, CREATIVE, etc.
  successCount      Int      @default(0)
  failureCount      Int      @default(0)
  totalAttempts     Int      @default(0)
  avgResponseTime   Int      @default(0) // milliseconds
  avgCost           Float    @default(0)
  totalCost         Float    @default(0)
  lastUsedAt        DateTime?
  preferenceScore   Float    @default(0.5) // 0-1, based on success rate
  confidenceLevel   Float    @default(0) // how confident we are in this preference
  embedding         Float[]  @default([]) // semantic embedding for this user+model combo
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, modelId, queryType])
  @@index([userId, preferenceScore])
  @@index([modelId, preferenceScore])
  @@index([userId, lastUsedAt])
}

// Model Performance Metrics - Aggregate performance data for models
model ModelPerformanceMetric {
  id                String   @id @default(uuid())
  modelId           String
  provider          String
  queryType         String   // CHAT, CODE, VISION, REASONING, CREATIVE
  period            String   // hourly, daily, weekly
  periodStart       DateTime
  periodEnd         DateTime
  totalRequests     Int      @default(0)
  successCount      Int      @default(0)
  failureCount      Int      @default(0)
  avgResponseTime   Int      @default(0) // milliseconds
  minResponseTime   Int?
  maxResponseTime   Int?
  avgTokensUsed     Int      @default(0)
  totalTokensUsed   Int      @default(0)
  avgCost           Float    @default(0)
  totalCost         Float    @default(0)
  errorRate         Float    @default(0) // 0-1
  healthScore       Float    @default(1) // 0-1, calculated from error rate and latency
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([modelId, queryType, period, periodStart])
  @@index([modelId, period])
  @@index([period, healthScore])
  @@index([periodEnd])
}

// Query Embeddings Cache - Store embeddings for frequently asked queries
model QueryEmbeddingCache {
  id          String   @id @default(uuid())
  queryHash   String   @unique
  query       String   @db.Text
  embedding   Float[]  // The semantic embedding vector
  queryType   String?  // CHAT, CODE, VISION, etc.
  confidence  Float    @default(0.8) // confidence in this embedding
  usageCount  Int      @default(0) // how many times this query was used
  lastUsedAt  DateTime?
  expiresAt   DateTime // TTL for cache invalidation
  createdAt   DateTime @default(now())

  @@index([queryHash])
  @@index([expiresAt])
  @@index([usageCount])
}

// Model Usage Analytics - Detailed analytics for model usage patterns
model ModelUsageAnalytics {
  id                String   @id @default(uuid())
  userId            String
  modelId           String
  provider          String
  queryType         String
  queryComplexity   String   // simple, medium, complex
  responseTime      Int      // milliseconds
  tokensUsed        Int
  cost              Float
  success           Boolean
  errorMessage      String?
  feedbackScore     Int?     // 1-5 rating from user
  semanticScore     Float?   // how well the model matched the query semantically
  preferenceScore   Float?   // how well this matches user's historical preference
  routingDecision   Json?    // metadata about routing decision
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([userId, modelId])
  @@index([modelId, createdAt])
  @@index([provider, success, createdAt])
  @@index([userId, createdAt])
}
